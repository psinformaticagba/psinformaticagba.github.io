source "https://rubygems.org"

# Gem principal do Jekyll
gem "jekyll", "~> 4.4"

# Plugins do projeto
gem "jekyll-seo-tag"

# Dependências de compatibilidade (Essencial para Ruby 3.4+ no Arch Linux)
# Estas bibliotecas foram removidas do core do Ruby e agora precisam ser gems
group :jekyll_plugins do
  gem "base64"
  gem "bigdecimal"
  gem "mutex_m"
  gem "webrick"
  gem "logger"
  gem "rexml"
  gem "erb"
end